# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*

# next.js
/.next/
/out/
/.turbo/

# production/build output
/build/
/dist/
backend/dist/

# test and coverage output
/coverage/

# debug/logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real env files but always track example templates
.env*
!.env.example
!**/.env.example

# local Next.js overrides
v0-user-next.config.*

# deployment
.vercel/
.netlify/

# typescript
*.tsbuildinfo
next-env.d.ts

# Rust/Soroban build output
/target/

# Solidity tool output
/artifacts/
/cache/
/typechain-types/
/broadcast/

# Python backend artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# package manager caches
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/

# editor/OS files
.DS_Store
Thumbs.db
.idea/
.vscode/

# local agent state
.qodo
.omx/
.codex
.remember/
.claude/
docs/superpowers/

# editor swap files
*.swp
*.swo
*~
